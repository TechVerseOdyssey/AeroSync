# Rust
/target/
**/*.rs.bk
# Cargo.lock IS committed — AeroSync ships binaries (CLI + MCP server),
# so reproducible dependency resolution matters. Per Cargo guidelines:
# binaries → commit lockfile; pure libraries → don't.

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Environment
.env
.env.local

# Build artifacts
/dist/
/build/

# Tauri
/src-tauri/target/

# Node modules (if using Tauri with frontend)
node_modules/

# Test files
/test_files/
/temp/

# AeroSync runtime state (resume checkpoints)
.aerosync/

# Personal TODO / scratch files (never committed)
TODO.local.md
*.local.md

# Python (aerosync-py wheel build artifacts and bytecode caches)
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
# `maturin develop` drops the compiled extension here; recreated on
# every build so it must never be committed.
aerosync-py/python/aerosync/_native*.so
aerosync-py/python/aerosync/_native*.dylib
aerosync-py/python/aerosync/_native*.pyd
# Python virtual environments. Contributors create one under
# aerosync-py/.venv to run `maturin develop` + pytest (see RELEASE
# checklist) — strictly local, never committed.
.venv/
**/.venv/
# `uv` lockfile under aerosync-py is generated incidentally by
# contributor `uv run pytest` invocations and is not the canonical
# resolver for the SDK (pip + maturin is). Keep it untracked so a
# clean `git status` after a local test run stays clean.
aerosync-py/uv.lock